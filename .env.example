# ── Billing proxy ─────────────────────────────────────────────────────────────
# DAYTONA_API_URL is hardcoded in docker-compose.yml (http://api:3000).
# Do NOT set it here — Daytona must not be reachable from outside the stack.
DAYTONA_ADMIN_KEY=          # Daytona admin API key (set in Daytona's ADMIN_API_KEY)

REDIS_PASSWORD=             # billing Redis password (leave blank for no auth in dev)

# TEE / Chain
# Production: TEE_SIGNING_KEY is injected by tapp-daemon via gRPC; leave blank.
# Development: set MOCK_TEE=true and MOCK_APP_PRIVATE_KEY instead.
TEE_SIGNING_KEY=
PROVIDER_ADDRESS=           # derived from TEE key if left blank
PROVIDER_PRIVATE_KEY=       # private key of the provider address (signs settlement txs)
                             # must match the address that called AddOrUpdateService on-chain
SETTLEMENT_CONTRACT=0x...   # BeaconProxy address (output of `go run ./cmd/deploy/`)
CHAIN_ID=16602
RPC_URL=https://evmrpc-testnet.0g.ai

# Billing parameters (all amounts in neuron; 1 0G = 10^18 neuron)
COMPUTE_PRICE_PER_SEC=16667 # neuron/sec per open sandbox (≈ 1M neuron/min)
CREATE_FEE=5000000          # neuron flat fee on sandbox creation
VOUCHER_INTERVAL_SEC=3600   # how often to flush compute vouchers to chain (seconds)

PORT=8080

# Local development only — do NOT set in production
# MOCK_TEE=true
# MOCK_APP_PRIVATE_KEY=0x<hex-private-key>

# ── Daytona internals ─────────────────────────────────────────────────────────
# These have safe defaults for local dev. Change in production.
DAYTONA_ENCRYPTION_KEY=supersecretkey
DAYTONA_ENCRYPTION_SALT=supersecretsalt
DAYTONA_DB_USER=user
DAYTONA_DB_PASSWORD=pass
DAYTONA_DB_NAME=daytona
DAYTONA_RUNNER_API_KEY=secret_api_token
DAYTONA_PROXY_API_KEY=super_secret_key
DAYTONA_SSH_GATEWAY_API_KEY=ssh_secret_api_token
# SSH gateway key pair — generate once per deployment (see README for commands)
DAYTONA_SSH_GATEWAY_PRIVATE_KEY=   # base64-encoded OpenSSH ed25519 private key
DAYTONA_SSH_GATEWAY_HOST_KEY=      # base64-encoded OpenSSH ed25519 host key (can reuse PRIVATE_KEY)
DAYTONA_HEALTH_CHECK_API_KEY=supersecretkey

# MinIO (sandbox object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Domain for sandbox HTTP port forwarding (Daytona proxy)
# Local: proxy.localhost:4000
# Production: your actual wildcard domain, e.g. proxy.example.com:4000
PROXY_DOMAIN=proxy.localhost:4000

# Runner domain (hostname where runner is reachable for sandbox networking)
# Local: localhost  Production: actual hostname/IP
RUNNER_DOMAIN=runner
